VISION_PROVIDER=zhipu
VISION_API_KEY=
VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
MODEL_NAME=glm-4.6v-flashx
VISION_ANALYZER_MODE=live
KIMI_CLI_COMMAND=kimi
FFMPEG_COMMAND=ffmpeg
FFPROBE_COMMAND=ffprobe
FRAME_INTERVAL=5
FRAME_MAX_WIDTH=1280
FRAME_JPEG_QUALITY=5
COARSE_INTERVAL=10
HASH_THRESHOLD=8
SUSPICIOUS_BUFFER=15.0
FINE_INTERVAL=3
FINE_SCAN_MODE=video
PROCESSING_MODE=two_stage
API_CONCURRENCY=3
TASK_WORKER_COUNT=1
API_MAX_RETRIES=6
API_MIN_INTERVAL_SECONDS=1.5
DB_PATH=data/db/search.db
# Alembic 会在容器启动时自动执行 `alembic upgrade head`，默认使用 DB_PATH 指向的数据库文件。
DATA_DIR=data
FRAMES_DIR=data/frames
# 前端构建与浏览器请求使用的 API Base URL。
VITE_API_BASE_URL=http://127.0.0.1:8000/api
# 前端构建与浏览器请求使用的 API Key，必须与下方 API_KEY 保持一致。
VITE_API_KEY=your_key_here
VIDEO_IMPORT_PATH=./作弊视频
ALLOW_ANY_VIDEO_PATHS=false

# 安全配置
# API认证密钥（生产环境必须设置）
API_KEY=your-secure-random-key-here

# CORS允许来源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 允许的视频目录（支持 ; 或 : 或换行分隔，便于跨平台兼容）
ALLOWED_VIDEO_DIRS=.;.\作弊视频;/app/videos
